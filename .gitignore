STM32/Debug/
STM32/Release/

# Specyficzne dla komputera / IDE
STM32/.settings/
STM32/.project
STM32/.cproject
STM32/.mxproject
STM32/*.swp
STM32/*.bak

# VS Code (odkomentuj jeśli nie chcesz wysyłać konfiguracji debuggera)
# STM32/.vscode/

# === Sekcja Python (Projekt w podfolderze Python_scripts/) ===

Python_scripts/__pycache__/
Python_scripts/*.pyc
Python_scripts/*.pyo
Python_scripts/*.pyd
Python_scripts/.venv/
Python_scripts/venv/
Python_scripts/env/

