STM32/build/
STM32/bin/
STM32/obj/
STM32/*.elf
STM32/*.bin
STM32/*.map
STM32/*.hex

# Pliki tymczasowe CubeMX i CubeIDE
STM32/mx.scratch
STM32/*.launch
STM32/*.pbi
STM32/*.browse
STM32/*.pbd
